# This file is a template of required environment variables for Corev.
# Copy it to `.env` and fill in the appropriate values.
# Do NOT commit your actual `.env` file to version control.

# === MongoDB ===
# MongoDB connection strings for production and test environments
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority
MONGO_URI_TEST=mongodb+srv://<username>:<password>@<cluster-url>/<test-dbname>?retryWrites=true&w=majority

# === API Server ===
# Port on which the backend API server will run
PORT=8080

# === Dashboard ===
# Port for the Next.js dashboard app
DASH_PORT=3001

# === Runtime Environment ===
# NODE_ENV should be 'development' or 'production'
NODE_ENV=production

# === JWT ===
# Secret key for signing JWT tokens (keep this secure)
JWT_SECRET=some-secret-key-here

# === SMTP (Mail) ===
# Email server configuration used for sending system emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=some@email.com
SMTP_PASS=some-password
SMTP_FROM="Some Name <some@email.com>"
